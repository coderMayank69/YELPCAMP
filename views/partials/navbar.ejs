          <li class="nav-item">
            <a class="nav-link <%= page === 'login' ? 'active' : '' %>" href="/login">Login</a>
          </li>
          <li class="nav-item">
            <a class="btn btn-primary btn-sm px-3 rounded-pill" href="/register">Register</a>
          </li>
