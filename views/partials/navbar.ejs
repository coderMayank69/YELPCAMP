          <li class="nav-item d-none d-lg-block">
            <span class="text-muted small">Hello, <%= currentUser.username %></span>
          </li>
          <li class="nav-item">
            <a class="btn btn-outline-primary btn-sm px-3 rounded-pill" href="/logout">Logout</a>
          </li>
