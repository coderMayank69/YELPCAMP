<% layout('layouts/boilerplate') %>

<div class="row justify-content-center">
  <div class="col-12 col-xl-10">
    <div class="card auth-card border-0 shadow-sm">
      <div class="row g-0 flex-column flex-md-row">
        <div class="col-md-5 col-lg-6 auth-visual auth-visual-login order-md-first"></div>
        <div class="col-md-7 col-lg-6">
          <div class="card-body p-4 p-lg-5">
            <h2 class="h3 fw-bold mb-1">Log in</h2>
            <p class="text-muted mb-4">Welcome back. Continue planning your next trip.</p>
            <form action="/login" method="POST" class="form-validate" novalidate>
              <div class="mb-3">
                <label class="form-label fw-medium" for="username">Username</label>
                <input class="form-control form-control-lg rounded-3" type="text" id="username" name="username" autofocus required>
                <div class="invalid-feedback">Please enter your username.</div>
              </div>
              <div class="mb-4">
                <label class="form-label fw-medium" for="password">Password</label>
                <input class="form-control form-control-lg rounded-3" type="password" id="password" name="password" required>
                <div class="invalid-feedback">Please enter your password.</div>
              </div>
              <button class="btn btn-primary btn-lg w-100 rounded-3" type="submit">Continue</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
