<% layout('layouts/boilerplate') %>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-body p-5 text-center">
                <h1 class="display-6 fw-bold mb-3 text-danger">Oops!</h1>
                <p class="lead text-muted mb-4"><%= err.message %></p>
                <% if (process.env.NODE_ENV !== "production"){ %>
                <pre class="bg-light p-3 rounded-3 text-start text-wrap"><%= err.stack %></pre>
                <% } %>
                <a href="/" class="btn btn-primary btn-lg mt-4 rounded-pill px-4">Return home</a>
            </div>
        </div>
    </div>
</div>
