<% layout('layouts/boilerplate') %>
<link rel="stylesheet" href="/stylesheets/stars.css">

<div class="row g-4">
  <div class="col-lg-7">
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
      <div id="campgroundCarousel" class="carousel slide">
        <div class="carousel-inner rounded-top">
          <% campground.images.forEach((img,i)=>{ %>
          <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
            <img crossorigin="anonymous" src="<%= img.url %>" class="d-block w-100 object-fit-cover" style="height: 360px;" alt="Campground image">
          </div>
          <% }) %>
        </div>
        <% if (campground.images.length > 1) { %>
        <button class="carousel-control-prev" type="button" data-bs-target="#campgroundCarousel" data-bs-slide="prev">
          <span class="carousel-control-prev-icon"></span>
          <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#campgroundCarousel" data-bs-slide="next">
          <span class="carousel-control-next-icon"></span>
          <span class="visually-hidden">Next</span>
        </button>
        <% } %>
      </div>
      <div class="card-body p-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-3">
          <div>
            <h2 class="fw-bold mb-1"><%= campground.title %></h2>
            <p class="text-muted mb-2"><i class="bi bi-geo-alt-fill me-2"></i><%= campground.location %></p>
          </div>
          <span class="badge bg-success fs-6">$<%= campground.price %>/night</span>
        </div>
        <p class="text-secondary mb-4"><%= campground.description %></p>
        <ul class="list-group list-group-flush mb-4 rounded-4 overflow-hidden border">
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <span>Submitted by</span>
            <strong><%= campground.author.username %></strong>
          </li>
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <span>Status</span>
            <span class="badge bg-info text-dark">Open for bookings</span>
          </li>
        </ul>
        <% 
          const authorId = campground.author && campground.author._id ? campground.author._id : null;
          const isAuthor = currentUser && authorId && (authorId.equals ? authorId.equals(currentUser._id) : String(authorId) === String(currentUser._id));
        %>
        <% if (isAuthor) { %>
        <div class="d-flex flex-wrap gap-3">
          <a class="btn btn-outline-primary rounded-3" href="/campgrounds/<%=campground._id%>/edit">Edit</a>
          <form class="d-inline" action="/campgrounds/<%=campground._id%>?_method=DELETE" method="POST">
            <button class="btn btn-outline-danger rounded-3" type="submit">Delete</button>
          </form>
        </div>
        <% } %>
      </div>
    </div>
  </div>

  <div class="col-lg-5">
    <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
      <div id="map" class="show-page-map"></div>
    </div>
    <% if(currentUser) {%>
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
      <div class="card-body p-4">
        <h3 class="h5 mb-3">Leave a Review</h3>
        <form action="/campgrounds/<%= campground._id %>/reviews" method="POST" class="form-validate" novalidate>
          <div class="mb-3">
            <fieldset class="starability-grow">
              <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
              <input type="radio" id="first-rate1" name="review[rating]" value="1" />
              <label for="first-rate1" title="Terrible">1 star</label>
              <input type="radio" id="first-rate2" name="review[rating]" value="2" />
              <label for="first-rate2" title="Not good">2 stars</label>
              <input type="radio" id="first-rate3" name="review[rating]" value="3" />
              <label for="first-rate3" title="Average">3 stars</label>
              <input type="radio" id="first-rate4" name="review[rating]" value="4" />
              <label for="first-rate4" title="Very good">4 stars</label>
              <input type="radio" id="first-rate5" name="review[rating]" value="5" />
              <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
          </div>
          <div class="mb-3">
            <label class="form-label" for="body">Review</label>
            <textarea class="form-control" name="review[body]" id="body" rows="3" required></textarea>
            <div class="invalid-feedback">Please add your review.</div>
          </div>
          <button class="btn btn-primary w-100" type="submit">Submit</button>
        </form>
      </div>
    </div>
    <% } %>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
      <div class="card-body p-4">
        <h3 class="h5 mb-4">Reviews</h3>
        <% if(campground.reviews.length === 0) { %>
          <p class="text-muted">No reviews yet. Be the first to leave feedback.</p>
        <% } %>
        <% for(let review of campground.reviews) { %>
          <div class="border-bottom py-3">
            <div class="d-flex justify-content-between align-items-center mb-2">
              <h6 class="mb-0"><%= review.author.username %></h6>
              <span class="badge bg-secondary">Rating <%= review.rating %>/5</span>
            </div>
            <p class="text-secondary mb-2"><%= review.body %></p>
            <% 
              const reviewAuthorId = review.author && review.author._id ? review.author._id : null;
              const canDeleteReview = currentUser && reviewAuthorId && (reviewAuthorId.equals ? reviewAuthorId.equals(currentUser._id) : String(reviewAuthorId) === String(currentUser._id));
            %>
            <% if (canDeleteReview) { %>
            <form action="/campgrounds/<%= campground._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
              <button class="btn btn-sm btn-outline-danger">Delete</button>
            </form>
            <% } %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
<% if (campground.geometry && campground.geometry.coordinates) { %>
  <script>
    const maptilerApiKey = '<%- maptilerApiKey %>';
    const campground = <%- JSON.stringify(campground) %>;
  </script>
  <script src="/javascripts/showPageMap.js"></script>
<% } %>
