<% layout('layouts/boilerplate') %>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-header bg-white border-bottom py-4 rounded-top-4">
        <h2 class="h4 fw-bold mb-0">Edit campground</h2>
      </div>
      <div class="card-body p-4">
        <form action="/campgrounds/<%= campground._id %>?_method=PUT" method="POST" novalidate class="form-validate" enctype="multipart/form-data">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label" for="title">Title</label>
              <input class="form-control" type="text" id="title" name="campground[title]" value="<%= campground.title %>" required>
              <div class="invalid-feedback">Please enter a title.</div>
            </div>
            <div class="col-md-6">
              <label class="form-label" for="location">Location</label>
              <input class="form-control" type="text" id="location" name="campground[location]" value="<%= campground.location %>" required>
              <div class="invalid-feedback">Please enter a location.</div>
            </div>
          </div>
          <div class="row g-3 mt-3">
            <div class="col-md-6">
              <label class="form-label" for="price">Price per night</label>
              <div class="input-group">
                <span class="input-group-text">$</span>
                <input class="form-control" type="text" id="price" name="campground[price]" value="<%= campground.price %>" required>
                <div class="invalid-feedback">Please enter a price.</div>
              </div>
            </div>
            <div class="col-md-6">
              <label class="form-label" for="image">Upload images</label>
              <input class="form-control" type="file" id="image" name="image" multiple>
            </div>
          </div>
          <div class="mt-3">
            <label class="form-label" for="description">Description</label>
            <textarea class="form-control" id="description" name="campground[description]" rows="5" required><%= campground.description %></textarea>
            <div class="invalid-feedback">Please enter a description.</div>
          </div>
          <div class="mt-4">
            <h5 class="mb-3">Current images</h5>
            <div class="row g-3">
              <% campground.images.forEach((img, i) => { %>
              <div class="col-6 col-md-4">
                <div class="card rounded-4 overflow-hidden border-0 shadow-sm">
                  <img src="<%= img.thumbnail %>" alt="Campground image" class="card-img-top object-fit-cover" style="height: 160px;">
                  <div class="card-body py-2 px-3">
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" name="deleteImages[]" id="image-<%= i %>" value="<%= img.filename %>">
                      <label class="form-check-label" for="image-<%= i %>">Delete</label>
                    </div>
                  </div>
                </div>
              </div>
              <% }) %>
            </div>
          </div>
          <div class="mt-4 text-end">
            <button class="btn btn-primary btn-lg px-5 rounded-3" type="submit">Save changes</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
