<% layout('layouts/boilerplate') %>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-header bg-white border-bottom py-4 rounded-top-4">
        <h2 class="h4 fw-bold mb-1">New campground</h2>
        <p class="text-muted mb-0 small">Add photos, a location, and a description guests will love.</p>
      </div>
      <div class="card-body p-4">
        <form action="/campgrounds" method="POST" novalidate class="form-validate" enctype="multipart/form-data">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label" for="title">Title</label>
              <input class="form-control" type="text" id="title" name="campground[title]" required>
              <div class="invalid-feedback">Please enter a title.</div>
            </div>
            <div class="col-md-6">
              <label class="form-label" for="location">Location</label>
              <input class="form-control" type="text" id="location" name="campground[location]" required>
              <div class="invalid-feedback">Please enter a location.</div>
            </div>
          </div>
          <div class="row g-3 mt-3">
            <div class="col-md-6">
              <label class="form-label" for="price">Price per night</label>
              <div class="input-group">
                <span class="input-group-text">$</span>
                <input class="form-control" type="text" id="price" name="campground[price]" placeholder="0.00" required>
                <div class="invalid-feedback">Please enter a price.</div>
              </div>
            </div>
            <div class="col-md-6">
              <label class="form-label" for="image">Upload images</label>
              <input class="form-control" type="file" id="image" name="image" multiple>
            </div>
          </div>
          <div class="mt-3">
            <label class="form-label" for="description">Description</label>
            <textarea class="form-control" id="description" name="campground[description]" rows="5" required></textarea>
            <div class="invalid-feedback">Please enter a description.</div>
          </div>
          <div class="mt-4 text-end">
            <button class="btn btn-primary btn-lg px-5 rounded-3" type="submit">Create listing</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
